# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Cursor rules (로컬 전용)
.cursor/rules/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (로컬/시크릿 — 커밋 제외)
.env
.env.local
.env.*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma Client (generated on postinstall / prisma generate)
/app/generated/prisma

# 실명·학번(로그인용) 등 — 커밋 금지. 예시는 seed-users.example.ts
/prisma/seed-users.ts
